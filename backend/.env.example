# ============================================================
# QRCodeAttend Backend — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
NODE_ENV=development
PORT=5000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/qrcodeattend?retryWrites=true&w=majority

# JWT Secrets (generate with: openssl rand -hex 64)
JWT_ACCESS_SECRET=your_super_secret_access_key_here_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Bcrypt
BCRYPT_ROUNDS=12

# Client URL (for CORS and email links)
CLIENT_URL=http://localhost:5173

# SMTP (Gmail example — use App Password if 2FA enabled)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_app_password_here

# Fingerprint Salt (generate with: openssl rand -hex 32)
FINGERPRINT_SALT=your_fingerprint_salt_here

# Logging
LOG_LEVEL=debug

# Rate Limiting (optional overrides)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=200
