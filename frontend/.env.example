# ============================================================
# QRCodeAttend Frontend — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# API Base URL (leave empty for local dev with proxy in vite.config.js)
VITE_API_URL=/api/v1

# Socket.IO URL (leave empty for local dev to use window.location.origin)
VITE_SOCKET_URL=

# App Name
VITE_APP_NAME=QRCodeAttend
